# Maxify Procurement Agent — Environment Variables

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://maxify:maxify@localhost:5432/procurement
DB_HOST=localhost
DB_PORT=5432
DB_NAME=procurement
DB_USER=maxify
DB_PASSWORD=maxify

# Redis (for Bull job queue)
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-jwt-secret-here
API_KEY_SALT=your-api-key-salt-here

# Maxia Calculator Integration
MAXIA_API_URL=https://api.gomaxify.com
MAXIA_EQUIPMENT_DB_PATH=./data/maxia_equipment.db

# Supplier: Fortune Energy
FORTUNE_ENERGY_API_KEY=
FORTUNE_ENERGY_DEALER_ID=

# Supplier: Krannich Solar
KRANNICH_API_KEY=
KRANNICH_CUSTOMER_ID=

# Supplier: BayWa r.e.
BAYWA_WEBSTORE_USER=
BAYWA_WEBSTORE_PASS=

# Supplier: Soligent
SOLIGENT_CONNECT_USER=
SOLIGENT_CONNECT_PASS=

# Supplier: Wesco (API Developer Portal)
WESCO_CLIENT_ID=
WESCO_CLIENT_SECRET=

# Notifications (Brevo)
BREVO_API_KEY=your-brevo-api-key-here
BREVO_WHATSAPP_NUMBER=your-brevo-whatsapp-sender-number-here
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_FROM=solana@solarandroof.pro

# Twilio (Fallback for SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Logging
LOG_LEVEL=info
